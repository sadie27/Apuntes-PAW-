---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  blockNumber: number;
  blockName: string;
  sections: { id: string; label: string }[];
}
const { title, blockNumber, blockName, sections } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — PAW</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&family=Literata:ital,opsz,wght@0,7..72,400;0,7..72,500;1,7..72,400&family=Fira+Code:wght@400;500&display=swap" />
    <style>
      :root {
        --navbar-height: 56px;
      }
    </style>
  </head>
  <body class="block-page">
    <Navbar />
    <div class="block-layout">
      <aside class="block-sidebar">
        <Sidebar sections={sections} />
      </aside>
      <main class="block-content">
        <slot />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  .block-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .block-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    flex: 1;
    align-items: start;
  }

  .block-sidebar {
    padding-top: var(--space-7);
    padding-left: var(--space-5);
  }

  .block-content {
    max-width: var(--measure-wide);
    padding: var(--space-7) var(--space-6);
  }
</style>

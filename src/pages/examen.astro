  <div class="code-block">
    <div class="code-header">Java</div>
    <pre><code>// Flujo MVC completo — ejemplo de "obtener detalle de un pedido"

// 1. CONTROLADOR — recibe la petición HTTP, delega al servicio
@Controller
public class PedidoController &#123;

    @Autowired
    private PedidoService pedidoService;

    @GetMapping("/pedidos/&#123;id&#125;")
    public String detalle(@PathVariable Long id, Model model) &#123;
        PedidoDTO pedido = pedidoService.obtenerPedido(id);  // delega al servicio
        model.addAttribute("pedido", pedido);                // pasa datos a la vista
        return "pedidos/detalle";                            // nombre de la plantilla
    &#125;
&#125;

// 2. SERVICIO — lógica de negocio, orquesta repositorios
@Service
public class PedidoService &#123;

    @Autowired
    private PedidoRepository pedidoRepository;

    @Transactional(readOnly = true)
    public PedidoDTO obtenerPedido(Long id) &#123;
        Pedido entidad = pedidoRepository.findById(id)
                         .orElseThrow(() -&gt; new NotFoundException("Pedido no encontrado"));
        return mapToDTO(entidad);
    &#125;
&#125;

// 3. REPOSITORIO — acceso a datos, sin lógica de negocio
@Repository
public interface PedidoRepository extends JpaRepository&lt;Pedido, Long&gt; &#123;
    // JPA genera el SQL; el repositorio solo declara qué se necesita
&#125;</code></pre>

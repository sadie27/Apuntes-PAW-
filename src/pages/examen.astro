    <text x="485" y="232" text-anchor="middle" class="svg-cn" font-size="12" fill="oklch(35% 0.12 155)">children[0] = &lt;span&gt;</text>
    <text x="485" y="252" text-anchor="middle" class="svg-cn" font-size="11" fill="oklch(62% 0.010 264)">(siempre el primer elemento)</text>
    <rect x="350" y="268" width="268" height="28" rx="4" fill="oklch(97% 0.03 155)" stroke="oklch(82% 0.08 155)" stroke-width="1"/>
    <text x="485" y="286" text-anchor="middle" class="svg-cn" font-size="11" fill="oklch(35% 0.12 155)">Solo nodos element (nodeType === 1)</text>

  <!-- Bloque de código JavaScript -->
  <div class="code-block">
    <div class="code-header">JavaScript</div>
    <pre><code>const div = document.getElementById("mio");

// ── childNodes: TODOS los nodos (texto, elementos, comentarios) ──────
// Si el HTML tiene espacios o saltos de línea entre etiquetas,
// esos son nodos de texto y CUENTAN en childNodes
const nodo = div.childNodes[1];
// CUIDADO: [1] puede ser un nodo de texto, no el primer &lt;elemento&gt;

// Iteración con childNodes → hay que filtrar por tipo
for (let c of div.childNodes) &#123;
    if (c.nodeType === Node.ELEMENT_NODE) &#123;  // nodeType 1 = Element (HTML)
        // Solo procesamos nodos que son elementos HTML
        console.log(c.tagName);
    &#125;
    // Otros tipos:
    // nodeType 3 = Text (texto y espacios en blanco)
    // nodeType 8 = Comment (comentarios HTML)
&#125;

// ── children: SOLO elementos HTML ────────────────────────────────────
// Equivalente a childNodes filtrado a nodeType === 1
const primerElemento = div.children[0];  // siempre el primer &lt;elemento&gt;, sin texto</code></pre>
  </div>

  <table class="comparison-table">
    <thead>
      <tr>
        <th>Propiedad</th>
        <th>Tipo retornado</th>
        <th>Nodos texto</th>
        <th>Comentarios</th>
        <th><code>[0]</code> = elemento</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>childNodes</code></td>
        <td><code>NodeList</code> (vivo)</td>
        <td>Sí</td>
        <td>Sí</td>
        <td>No garantizado</td>
      </tr>
      <tr>
        <td><code>children</code></td>
        <td><code>HTMLCollection</code> (vivo)</td>
        <td>No</td>
        <td>No</td>
        <td>Sí, siempre</td>
      </tr>
      <tr>
        <td><code>querySelectorAll()</code></td>
        <td><code>NodeList</code> (estático)</td>
        <td>No</td>
        <td>No</td>
        <td>Sí, siempre</td>
      </tr>
    </tbody>
  </table>

  <div class="callout callout-warning">
    Trampa de examen clásica: <code>div.childNodes[1]</code> NO es el segundo elemento HTML hijo.
    Si hay espacios o saltos de línea en el HTML, <code>childNodes[0]</code> puede ser un nodo de
    texto (<code>nodeType === 3</code>). Usar <code>div.children[1]</code> para acceder al segundo
    elemento HTML de forma fiable.
  </div>

  <div class="callout callout-key">
    Regla práctica: si necesitas iterar solo por elementos HTML, usa <code>children</code> o
    <code>querySelectorAll()</code>. Si necesitas acceder también a nodos de texto (por ejemplo,
    para manipular el contenido textual directo), usa <code>childNodes</code>.
  </div>

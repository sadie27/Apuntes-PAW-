        <text x="225" y="62" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-warning-text)" text-anchor="middle">ListadoServlet</text>
        <text x="225" y="76" font-family="var(--font-display)" font-size="8" fill="var(--color-warning-text)" text-anchor="middle">auth + log + encoding</text>

        <rect x="160" y="100" width="130" height="40" rx="4" fill="var(--color-warning-bg)" stroke="var(--color-warning-border)" stroke-width="1"/>
        <text x="225" y="118" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-warning-text)" text-anchor="middle">CrearServlet</text>
        <text x="225" y="132" font-family="var(--font-display)" font-size="8" fill="var(--color-warning-text)" text-anchor="middle">auth + log + encoding</text>

        <rect x="160" y="156" width="130" height="40" rx="4" fill="var(--color-warning-bg)" stroke="var(--color-warning-border)" stroke-width="1"/>
        <text x="225" y="174" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-warning-text)" text-anchor="middle">EditarServlet</text>
        <text x="225" y="188" font-family="var(--font-display)" font-size="8" fill="var(--color-warning-text)" text-anchor="middle">auth + log + encoding</text>

        <!-- flechas browser → 3 servlets -->

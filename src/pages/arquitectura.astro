        <text x="280" y="78" font-family="var(--font-display)" font-size="11" font-weight="600" fill="var(--color-accent)" text-anchor="middle">Controller</text>
        <path d="M360 82 L400 82" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#arrFwdA)"/>
        <text x="440" y="78" font-family="var(--font-display)" font-size="11" font-weight="600" fill="var(--color-accent)" text-anchor="middle">Vista</text>
        <text x="370" y="74" font-family="var(--font-display)" font-size="9" fill="var(--color-accent)">forward</text>

        <!-- browser → servidor (forward) -->
        <rect x="20" y="56" width="100" height="52" rx="5" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1"/>
        <text x="70" y="87" font-family="var(--font-display)" font-size="11" fill="var(--color-text-2)" text-anchor="middle">Browser</text>
        <path d="M120 82 L180 82" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#arrFwdA)"/>
        <text x="150" y="75" font-family="var(--font-display)" font-size="9" fill="var(--color-accent)">GET /ctrl</text>

        <!-- respuesta HTML al browser (forward, misma request) -->
        <path d="M560 82 L620 82" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#arrFwdA)"/>

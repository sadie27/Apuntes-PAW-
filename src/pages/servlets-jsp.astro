    <table class="comparison-table">
      <thead>
        <tr><th>Elemento</th><th>Sintaxis</th><th>Estado</th><th>Alternativa</th></tr>
      </thead>
      <tbody>
        <tr><td>Scriptlet</td><td><code>&lt;% código Java %&gt;</code></td><td>Prohibido</td><td>EL + JSTL</td></tr>
        <tr><td>Expresión</td><td><code>&lt;%= valor %&gt;</code></td><td>Prohibido</td><td><code>$&#123;valor&#125;</code> con EL</td></tr>
        <tr><td>Declaración</td><td><code>&lt;%! var/método %&gt;</code></td><td>Prohibido</td><td>Clase Java separada</td></tr>
        <tr><td>Directiva <code>page</code></td><td><code>&lt;%@ page ... %&gt;</code></td><td>OK</td><td>—</td></tr>
        <tr><td>Directiva <code>taglib</code></td><td><code>&lt;%@ taglib ... %&gt;</code></td><td>Necesario</td><td>—</td></tr>
        <tr><td>EL</td><td><code>$&#123;expresión&#125;</code></td><td>Usar</td><td>—</td></tr>
        <tr><td>JSTL</td><td><code>&lt;c:forEach&gt;</code>, etc.</td><td>Usar</td><td>—</td></tr>
      </tbody>
    </table>

    <div class="code-block">
      <div class="code-block-header">jsp</div>
      <pre><code>&lt;%-- ❌ JSP con scriptlets — difícil de mantener --%&gt;
&lt;%@ page contentType="text/html;charset=UTF-8" %&gt;
&lt;ul&gt;
&lt;% List&lt;Articulo&gt; arts = (List&lt;Articulo&gt;) request.getAttribute("articulos");
   for (Articulo a : arts) &#123; %&gt;
  &lt;li&gt;&lt;%= a.getNombre() %&gt; — &lt;%= a.getPrecio() %&gt; €&lt;/li&gt;
&lt;% &#125; %&gt;
&lt;/ul&gt;</code></pre>
    </div>

    <div class="code-block">
      <div class="code-block-header">jsp</div>
      <pre><code>&lt;%-- ✓ JSP moderno: solo EL y JSTL --%&gt;
&lt;%@ page contentType="text/html;charset=UTF-8" %&gt;
&lt;%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %&gt;
&lt;ul&gt;
  &lt;c:forEach items="$&#123;articulos&#125;" var="a"&gt;
    &lt;li&gt;$&#123;a.nombre&#125; — $&#123;a.precio&#125; €&lt;/li&gt;
  &lt;/c:forEach&gt;
&lt;/ul&gt;</code></pre>
    </div>

    <div class="callout callout-key">
      <p>En JSP moderno: cero scriptlets. Solo EL (<code>$&#123;...&#125;</code>) y JSTL. El HTML debe ser legible sin conocer Java.</p>
    </div>

    <table class="comparison-table">
      <thead>
        <tr><th>Nombre en JSP</th><th>Tipo Jakarta EE</th><th>Equivalente en Servlet</th></tr>
      </thead>
      <tbody>
        <tr><td><code>request</code> / <code>$&#123;param&#125;</code></td><td>HttpServletRequest</td><td>parámetro del método doXxx</td></tr>
        <tr><td><code>session</code> / <code>$&#123;sessionScope&#125;</code></td><td>HttpSession</td><td><code>request.getSession()</code></td></tr>
        <tr><td><code>application</code> / <code>$&#123;applicationScope&#125;</code></td><td>ServletContext</td><td><code>getServletContext()</code></td></tr>
        <tr><td><code>$&#123;cookie&#125;</code></td><td>Map de Cookie</td><td><code>request.getCookies()</code></td></tr>
        <tr><td><code>out</code></td><td>JspWriter</td><td><code>response.getWriter()</code></td></tr>
      </tbody>
    </table>
  </section>

  <!-- ===== SECCIÓN 6: EL Y JSTL ===== -->
  <section id="el-jstl">
    <h2>EL y JSTL</h2>

    <div class="callout callout-examen">
      <p>Peso bajo. Leer para contexto; no memorizar la API completa. Sí entender <code>$&#123;sessionScope.usuario.nombre&#125;</code> y <code>&lt;c:forEach&gt;</code> básico.</p>
    </div>

    <svg viewBox="0 0 760 110" xmlns="http://www.w3.org/2000/svg" style="width:100%;max-width:760px;display:block;margin:var(--space-5) 0;">
      <defs>
        <marker id="arr6" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
          <path d="M0,0 L0,6 L8,3 z" fill="var(--color-text-2)"/>
        </marker>
      </defs>
      <!-- EL expression -->
      <rect x="10" y="30" width="110" height="36" rx="6" fill="var(--color-key-bg)" stroke="var(--color-key-border)" stroke-width="1.5"/>
      <text x="65" y="52" text-anchor="middle" font-family="var(--font-mono)" font-size="12" fill="var(--color-key-text)">$&#123;articulo&#125;</text>
      <line x1="122" y1="48" x2="148" y2="48" stroke="var(--color-text-2)" stroke-width="1.5" marker-end="url(#arr6)"/>
      <!-- pageScope -->
      <rect x="150" y="30" width="90" height="36" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
      <text x="195" y="52" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-2)">pageScope</text>
      <line x1="242" y1="48" x2="263" y2="48" stroke="var(--color-text-2)" stroke-width="1.5" marker-end="url(#arr6)"/>
      <text x="252" y="38" text-anchor="middle" font-family="var(--font-display)" font-size="8" fill="var(--color-text-3)">?</text>
      <!-- requestScope — highlighted -->
      <rect x="265" y="24" width="100" height="48" rx="6" fill="var(--color-accent-light)" stroke="var(--color-accent)" stroke-width="1.5"/>
      <text x="315" y="46" text-anchor="middle" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-accent)">requestScope</text>
      <text x="315" y="62" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-accent)">✓ encontrado</text>
      <line x1="367" y1="48" x2="388" y2="48" stroke="var(--color-text-3)" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arr6)"/>
      <!-- sessionScope -->
      <rect x="390" y="30" width="100" height="36" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5" opacity="0.5"/>
      <text x="440" y="52" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)">sessionScope</text>
      <line x1="492" y1="48" x2="513" y2="48" stroke="var(--color-text-3)" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arr6)"/>
      <!-- applicationScope -->
      <rect x="515" y="30" width="110" height="36" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5" opacity="0.4"/>
      <text x="570" y="52" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)">applicationScope</text>
      <line x1="627" y1="48" x2="648" y2="48" stroke="var(--color-text-3)" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arr6)"/>
      <!-- null -->
      <rect x="650" y="30" width="50" height="36" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1" opacity="0.4"/>
      <text x="675" y="52" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-3)">null</text>
      <text x="380" y="95" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)">EL busca en orden hasta encontrar el valor o devolver null</text>
    </svg>

    <p>EL (<code>$&#123;...&#125;</code>) simplifica el acceso a objetos en los ámbitos sin casting, con acceso a propiedades por punto (llama a getters automáticamente). Soporta operadores aritméticos, relacionales y ternario.</p>

    <table class="comparison-table">
      <thead>
        <tr><th>Etiqueta</th><th>Uso</th></tr>
      </thead>
      <tbody>
        <tr><td><code>&lt;c:out value="..."&gt;</code></td><td>Imprime con escape HTML automático</td></tr>
        <tr><td><code>&lt;c:set var="x" value="..." scope=""&gt;</code></td><td>Define variable en un scope</td></tr>
        <tr><td><code>&lt;c:if test="$&#123;...&#125;"&gt;</code></td><td>Condicional simple</td></tr>
        <tr><td><code>&lt;c:choose&gt;/&lt;c:when&gt;/&lt;c:otherwise&gt;</code></td><td>If–else complejo (switch)</td></tr>
        <tr><td><code>&lt;c:forEach items="$&#123;lista&#125;" var="x"&gt;</code></td><td>Iterar colección</td></tr>
        <tr><td><code>&lt;c:forEach begin="1" end="10" var="i"&gt;</code></td><td>Iterar rango numérico</td></tr>
        <tr><td><code>&lt;c:url value="/path"&gt;</code></td><td>URL con encoding correcto</td></tr>
        <tr><td><code>&lt;c:redirect url="..."&gt;</code></td><td>Redirect desde JSP (mejor en servlet)</td></tr>
      </tbody>
    </table>

    <div class="code-block">
      <div class="code-block-header">jsp</div>
      <pre><code>&lt;%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %&gt;
&lt;%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %&gt;

&lt;%-- 1. Acceso a sesión --%&gt;
&lt;c:if test="$&#123;sessionScope.usuario != null&#125;"&gt;
  &lt;p&gt;Bienvenido, $&#123;sessionScope.usuario.nombre&#125;&lt;/p&gt;
&lt;/c:if&gt;

&lt;%-- 2. Iterar lista del request --%&gt;
&lt;ul&gt;
  &lt;c:forEach items="$&#123;requestScope.articulos&#125;" var="art" varStatus="st"&gt;
    &lt;li&gt;$&#123;st.count&#125;. $&#123;art.nombre&#125; — $&#123;art.precio&#125; €&lt;/li&gt;
  &lt;/c:forEach&gt;
&lt;/ul&gt;

&lt;%-- 3. Condicional choose --%&gt;
&lt;c:choose&gt;
  &lt;c:when test="$&#123;empty articulos&#125;"&gt;
    &lt;p&gt;No hay artículos disponibles.&lt;/p&gt;
  &lt;/c:when&gt;
  &lt;c:otherwise&gt;
    &lt;p&gt;Se muestran $&#123;fn:length(articulos)&#125; artículos.&lt;/p&gt;
  &lt;/c:otherwise&gt;
&lt;/c:choose&gt;</code></pre>
    </div>

    <div class="callout callout-tip">
      <p>EL implícitos más útiles en el examen: <code>$&#123;param.nombre&#125;</code> (parámetros de la petición), <code>$&#123;sessionScope.usuario&#125;</code> (sesión), <code>$&#123;cookie.JSESSIONID.value&#125;</code> (cookie de sesión).</p>
    </div>
  </section>

  <!-- ===== SECCIÓN 7: ÁMBITOS ===== -->
  <section id="scopes">
    <h2>Ámbitos de datos</h2>

    <div class="callout callout-examen">
      <p>Peso alto. La diferencia request vs session scope es fundamental. ¿Qué se guarda en request? ¿Qué en session? Referencia directa: P4 S1, P5 y P6.</p>
    </div>

    <svg viewBox="0 0 720 300" xmlns="http://www.w3.org/2000/svg" style="width:100%;max-width:720px;display:block;margin:var(--space-5) 0;">
      <!-- application -->
      <rect x="10" y="10" width="700" height="280" rx="8" fill="var(--color-key-bg)" stroke="var(--color-key-border)" stroke-width="1.5"/>
      <text x="24" y="32" font-family="var(--font-display)" font-size="11" font-weight="700" fill="var(--color-key-text)">application · toda la aplicación</text>
      <text x="24" y="50" font-family="var(--font-display)" font-size="10" fill="var(--color-key-text)">DataSource, configuración global, estadísticas</text>
      <!-- session -->
      <rect x="40" y="65" width="640" height="200" rx="8" fill="var(--color-relation-bg)" stroke="var(--color-relation-border)" stroke-width="1.5"/>
      <text x="54" y="84" font-family="var(--font-display)" font-size="11" font-weight="700" fill="var(--color-relation-text)">session · sesión del usuario</text>
      <text x="54" y="100" font-family="var(--font-display)" font-size="10" fill="var(--color-relation-text)">usuario autenticado, carrito de la compra</text>
      <!-- request -->
      <rect x="70" y="115" width="580" height="120" rx="8" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1.5"/>
      <text x="84" y="133" font-family="var(--font-display)" font-size="11" font-weight="700" fill="var(--color-tip-text)">request · una petición / cadena de forwards</text>
      <text x="84" y="150" font-family="var(--font-display)" font-size="10" fill="var(--color-tip-text)">listado de artículos, errores de validación</text>
      <!-- page -->
      <rect x="100" y="165" width="520" height="56" rx="8" fill="var(--color-warning-bg)" stroke="var(--color-warning-border)" stroke-width="1.5"/>
      <text x="114" y="185" font-family="var(--font-display)" font-size="11" font-weight="700" fill="var(--color-warning-text)">page · un solo JSP</text>
      <text x="114" y="202" font-family="var(--font-display)" font-size="10" fill="var(--color-warning-text)">variables auxiliares de la vista</text>
    </svg>

    <table class="comparison-table">
      <thead>
        <tr><th>Ámbito</th><th>Duración</th><th>API en Servlet</th><th>EL</th><th>Usar para…</th></tr>
      </thead>
      <tbody>
        <tr><td><code>page</code></td><td>Solo el JSP actual</td><td>No existe en servlets</td><td><code>pageContext</code></td><td>Variables locales del JSP</td></tr>
        <tr><td><code>request</code></td><td>Una petición (o chain de forwards)</td><td><code>req.setAttribute/getAttribute</code></td><td><code>$&#123;nombre&#125;</code></td><td>Pasar datos de controller a vista</td></tr>
        <tr><td><code>session</code></td><td>Sesión del usuario</td><td><code>session.setAttribute/getAttribute</code></td><td><code>$&#123;sessionScope.nombre&#125;</code></td><td>Autenticación, carrito</td></tr>
        <tr><td><code>application</code></td><td>Toda la aplicación</td><td><code>ctx.setAttribute/getAttribute</code></td><td><code>$&#123;applicationScope.nombre&#125;</code></td><td>Config. global, recursos cacheados</td></tr>
      </tbody>
    </table>

    <p>La regla de oro: usar el scope más pequeño que cubra la necesidad.</p>

    <div class="callout callout-key">
      <p>Regla de oro: request para pasar datos del controlador a la vista. session solo para lo que debe sobrevivir entre peticiones del mismo usuario. Nunca usar session para lo que cabe en request.</p>
    </div>

    <div class="callout callout-warning">
      <p>Los objetos en session deben implementar <code>Serializable</code>. Una session grande penaliza el rendimiento, especialmente con balanceo de carga.</p>
    </div>

    <div class="code-block">
      <div class="code-block-header">java</div>
      <pre><code>protected void doGet(HttpServletRequest req, HttpServletResponse resp)
    throws ServletException, IOException &#123;
  // request scope: datos temporales para esta vista
  req.setAttribute("articulos", servicioArticulos.getListado());

  // session scope: datos persistentes entre peticiones del usuario
  HttpSession session = req.getSession(false); // no crear si no existe
  Usuario usuario = (session != null)
    ? (Usuario) session.getAttribute("usuario")
    : null;

  // application scope: datos globales (raramente se escribe aquí)
  String version = (String) getServletContext().getAttribute("app.version");

  req.getRequestDispatcher("/vistas/listado.jsp").forward(req, resp);
&#125;</code></pre>
    </div>
  </section>

  <!-- ===== SECCIÓN 8: PATRÓN PRG ===== -->
<!-- PENDIENTE:patrones-prg -->
<section id="patrones-prg">
  <h2>Patrón PRG</h2>

  <div class="callout callout-examen">
    <p>Peso muy alto. El patrón PRG resuelve el problema del botón recargar en formularios POST. Aparece explícitamente en P4 S2. El profesor lo menciona en la tutoría. Muy probable en el examen.</p>
  </div>

  <p>El problema: HTTP es sin estado. Si la última acción del navegador fue un POST a <code>/comprar</code>, al pulsar F5 se repite el POST (otra compra no deseada). La solución NO es desactivar el botón de recarga.</p>
  <p>La solución PRG: separar la operación en dos controladores con dos URLs. El primero procesa (POST) y redirige (302). El segundo solo muestra (GET). En el navegador queda la URL del GET, que se puede repetir sin efecto secundario.</p>

  <table class="comparison-table">
    <thead>
      <tr><th>Tipo</th><th>Descripción</th><th>Verbo habitual</th><th>¿Peligro con F5?</th></tr>
    </thead>
    <tbody>
      <tr><td>Informativa</td><td>Solo muestra datos, no modifica el modelo</td><td>GET</td><td>No — es seguro</td></tr>
      <tr><td>Funcional</td><td>Modifica el estado de la aplicación (crear, borrar…)</td><td>POST / PUT / DELETE</td><td>Sí — problema</td></tr>
    </tbody>
  </table>

  <svg viewBox="0 0 780 300" xmlns="http://www.w3.org/2000/svg" style="width:100%;max-width:780px;display:block;margin:var(--space-5) 0;">
    <defs>
      <marker id="arrPRG" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--color-text-2)"/>
      </marker>
      <marker id="arrPRGa" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="var(--color-accent)"/>
      </marker>
    </defs>
    <!-- Actor lines -->
    <line x1="80" y1="40" x2="80" y2="270" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>
    <line x1="350" y1="40" x2="350" y2="270" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>
    <line x1="620" y1="40" x2="620" y2="270" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>
    <!-- Actor labels -->
    <rect x="20" y="10" width="120" height="30" rx="4" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
    <text x="80" y="29" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-text)">Navegador</text>
    <rect x="270" y="10" width="160" height="30" rx="4" fill="var(--color-accent-light)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="350" y="29" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-accent)">Servidor A (POST /comprar)</text>
    <rect x="545" y="10" width="150" height="30" rx="4" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
    <text x="620" y="29" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-text)">Servidor B (GET /carro)</text>
    <!-- Step 1 -->
    <line x1="82" y1="70" x2="348" y2="70" stroke="var(--color-text-2)" stroke-width="1.5" marker-end="url(#arrPRG)"/>
    <text x="215" y="63" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-2)">① POST /comprar?id=123</text>
    <text x="215" y="88" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">Petición funcional</text>
    <!-- Step 2: internal -->
    <rect x="290" y="100" width="120" height="28" rx="4" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="350" y="118" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-text-2)">servicioCompras.añadir()</text>
    <!-- Step 3: redirect -->
    <line x1="348" y1="148" x2="84" y2="148" stroke="var(--color-accent)" stroke-width="2" marker-end="url(#arrPRGa)"/>
    <text x="215" y="142" text-anchor="middle" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-accent)">③ 302 Redirect → /carro</text>
    <text x="215" y="163" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-accent)">Location: /carro</text>
    <!-- Step 4 -->
    <line x1="82" y1="188" x2="618" y2="188" stroke="var(--color-text-2)" stroke-width="1.5" marker-end="url(#arrPRG)"/>
    <text x="350" y="181" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-2)">④ GET /carro</text>
    <text x="350" y="205" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">Nueva petición. Petición informativa.</text>
    <!-- Step 5 -->
    <line x1="618" y1="228" x2="84" y2="228" stroke="var(--color-text-2)" stroke-width="1.5" marker-end="url(#arrPRG)"/>
    <text x="350" y="222" text-anchor="middle" font-family="var(--font-display)" font-size="10" fill="var(--color-text-2)">⑤ HTML (estado actualizado)</text>
    <!-- Note -->
    <text x="390" y="265" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)">F5 aquí repite GET /carro — completamente seguro.</text>
  </svg>

  <div class="callout callout-key">
    <p>El POST procesa y redirige (302). El GET muestra. F5 solo repite el GET. Dos controladores, dos URLs.</p>
  </div>

  <div class="code-block">
    <div class="code-block-header">java</div>
    <pre><code>// Controlador 1: Procesa la acción (POST)
@WebServlet(urlPatterns = &#123;"/comprar"&#125;)
public class ComprarController extends HttpServlet &#123;
  protected void doPost(HttpServletRequest req, HttpServletResponse resp)
      throws ServletException, IOException &#123;
    req.setCharacterEncoding("UTF-8"); // primera línea en todo doPost con formularios
    String idProducto = req.getParameter("id");

    // 1. Acción funcional: modifica el modelo
    servicioCompras.añadirAlCarro(req.getSession(), idProducto);

    // 2. PRG: redirigir a la URL informativa
    resp.sendRedirect(req.getContextPath() + "/carro");
  &#125;
&#125;

// Controlador 2: Muestra el resultado (GET)
@WebServlet(urlPatterns = &#123;"/carro"&#125;)
public class CarroController extends HttpServlet &#123;
  protected void doGet(HttpServletRequest req, HttpServletResponse resp)
      throws ServletException, IOException &#123;
    // 3. Leer el modelo ya actualizado
    Carro carro = servicioCompras.getCarro(req.getSession());
    req.setAttribute("carro", carro);

    // 4. Delegar a la vista
    req.getRequestDispatcher("/vistas/carro.jsp").forward(req, resp);
  &#125;
&#125;</code></pre>
  </div>

  <div class="callout callout-warning">
    <p>Error clásico: olvidar el <code>sendRedirect</code> en el POST y usar <code>forward</code> directamente. Resultado: F5 repite la compra. El patrón PRG existe exactamente para evitar esto.</p>
  </div>

  <h3>Flash scope: mensajes tras el redirect</h3>

  <p>PRG resuelve el F5, pero introduce un nuevo problema: al redirigir, el navegador hace una nueva petición y los datos del <code>request.setAttribute()</code> se pierden. ¿Cómo mostrar "Artículo añadido al carro" en el GET después del redirect?</p>
  <p>El patrón flash scope lo resuelve: guardar el mensaje en session en el POST y leerlo y borrarlo inmediatamente en el GET. El mensaje existe durante un único ciclo POST → redirect → GET; no contamina peticiones posteriores.</p>

  <div class="code-block">
    <div class="code-block-header">java</div>
    <pre><code>// === POST: procesar + guardar flash + redirigir ===
protected void doPost(HttpServletRequest req, HttpServletResponse resp)
    throws ServletException, IOException &#123;
  req.setCharacterEncoding("UTF-8");
  servicioCompras.añadirAlCarro(req.getSession(), req.getParameter("id"));

  // Flash scope: mensaje que sobrevive exactamente UN redirect
  req.getSession().setAttribute("flash", "Artículo añadido al carro");
  resp.sendRedirect(req.getContextPath() + "/carro");
&#125;

// === GET: leer flash → borrar de session → pasar a request para la vista ===
protected void doGet(HttpServletRequest req, HttpServletResponse resp)
    throws ServletException, IOException &#123;
  HttpSession session = req.getSession(false);
  if (session != null) &#123;
    String flash = (String) session.getAttribute("flash");
    if (flash != null) &#123;
      session.removeAttribute("flash"); // IMPORTANTE: borrar para que no reaparezca
      req.setAttribute("flash", flash); // mover a request scope para el JSP
    &#125;
  &#125;
  Carro carro = servicioCompras.getCarro(req.getSession(false));
  req.setAttribute("carro", carro);
  req.getRequestDispatcher("/vistas/carro.jsp").forward(req, resp);
&#125;</code></pre>
  </div>

  <div class="code-block">
    <div class="code-block-header">jsp</div>
    <pre><code>&lt;%-- En carro.jsp: mostrar el mensaje flash si existe --%&gt;
&lt;c:if test="$&#123;flash != null&#125;"&gt;
  &lt;p class="flash-ok"&gt;$&#123;flash&#125;&lt;/p&gt;
&lt;/c:if&gt;

&lt;!-- Después del GET: flash == null, el mensaje no vuelve a aparecer --&gt;</code></pre>
  </div>

  <div class="callout callout-key">
    <p>Flash scope = session como almacén temporal de un solo uso. Patrón: <code>setAttribute</code> en el POST → <code>removeAttribute</code> en el GET siguiente → la vista lo muestra una sola vez.</p>
  </div>

  <div class="callout callout-relation">
    <p>El flash scope usa session como transporte, pero se limpia inmediatamente. Es diferente a guardar datos permanentes en session. Algunos frameworks (Spring MVC con <code>RedirectAttributes</code>) implementan este patrón de forma nativa.</p>
  </div>
</section>
<!-- /PENDIENTE:patrones-prg -->


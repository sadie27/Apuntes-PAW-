      <text x="85" y="96" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-text-3)">&lt;c:forEach ...&gt;</text>
      <text x="85" y="138" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">Plantilla HTML + EL + JSTL</text>

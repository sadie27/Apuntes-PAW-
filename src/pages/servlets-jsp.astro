    <circle cx="80" cy="60" r="6" fill="var(--color-accent)"/>
    <rect x="20" y="75" width="160" height="60" rx="4" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1.5"/>
    <text x="100" y="93" text-anchor="middle" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-tip-text)">Primera petición</text>
    <text x="100" y="109" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-tip-text)">Sesión creada.</text>
    <text x="100" y="123" text-anchor="middle" font-family="var(--font-mono)" font-size="8" fill="var(--color-tip-text)">Set-Cookie: JSESSIONID=abc</text>
    <!-- Event 2: Petición 2 x=353 -->
    <circle cx="353" cy="60" r="6" fill="var(--color-accent)"/>
    <rect x="273" y="75" width="160" height="60" rx="4" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1.5"/>
    <text x="353" y="93" text-anchor="middle" font-family="var(--font-display)" font-size="10" font-weight="600" fill="var(--color-tip-text)">Petición 2 con cookie</text>
    <text x="353" y="109" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-tip-text)">Sesión encontrada</text>

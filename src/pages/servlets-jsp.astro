      </marker>
    </defs>
    <!-- LEFT: HTML form -->
    <rect x="10" y="20" width="300" height="170" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
    <text x="160" y="42" text-anchor="middle" font-family="var(--font-display)" font-size="11" font-weight="700" fill="var(--color-text)">Formulario HTML</text>
    <rect x="24" y="52" width="272" height="28" rx="3" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1"/>
    <text x="160" y="70" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-tip-text)">method="POST"</text>

    <text x="630" y="108" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">sesión destruida</text>
    <text x="630" y="122" text-anchor="middle" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">automáticamente</text>
    <!-- Event 4: invalidate() x=920 -->
    <circle cx="920" cy="60" r="6" fill="var(--color-text-3)"/>

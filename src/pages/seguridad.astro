      <rect x="20"  y="85" width="140" height="36" rx="6" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"/>
      <text x="90"  y="107" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--color-text)">cliente1</text>

      <rect x="20"  y="135" width="140" height="36" rx="6" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1.5"/>
      <text x="90"  y="157" text-anchor="middle" font-family="var(--font-mono)" font-size="11" fill="var(--color-text)">gestor</text>

      <!-- Roles -->

      <line x1="640" y1="28" x2="640" y2="255" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>

      <!-- Fase A: sesión activa -->
      <text x="8" y="52" font-family="var(--font-display)" font-size="9" fill="var(--color-text-3)">SÍ sesión</text>

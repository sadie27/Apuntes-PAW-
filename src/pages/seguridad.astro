        </marker>
        <marker id="arrN" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
          <path d="M0,0 L0,6 L8,3 z" fill="var(--color-text-3)"/>
        </marker>
      </defs>

      <!-- Actores -->
      <text x="60" y="22" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--color-text-2)">Cliente</text>
      <line x1="60" y1="28" x2="60" y2="255" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>

      <text x="240" y="22" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--color-text-2)">Filtro Auth</text>
      <line x1="240" y1="28" x2="240" y2="255" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>

      <text x="430" y="22" text-anchor="middle" font-family="var(--font-display)" font-size="12" font-weight="600" fill="var(--color-text-2)">Servicio Login</text>
      <line x1="430" y1="28" x2="430" y2="255" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>


        <rect x="22" y="282" width="90" height="18" rx="3" fill="oklch(97% 0.03 0 / 0.8)" stroke="oklch(82% 0.08 0)" stroke-width="1"/>
        <text x="30" y="295" font-family="var(--font-mono)" font-size="9" fill="oklch(38% 0.12 0)">&lt;li&gt;borrar&lt;/li&gt;</text>
        <text x="146" y="290" font-family="var(--font-mono)" font-size="9" fill="var(--color-accent)">elemento.remove()</text>
        <line x1="240" y1="288" x2="268" y2="288" stroke="var(--color-accent)" stroke-width="2" marker-end="url(#arr-manip)"/>

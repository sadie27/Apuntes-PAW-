        <line x1="240" y1="70" x2="268" y2="70" stroke="var(--color-accent)" stroke-width="2" marker-end="url(#arr-manip)"/>
        <rect x="270" y="38" width="120" height="78" rx="4" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1"/>
        <text x="282" y="58" font-family="var(--font-mono)" font-size="10" fill="var(--color-text)">ul#lista</text>
        <rect x="282" y="64" width="90" height="18" rx="3" fill="var(--color-key-bg)" stroke="var(--color-key-border)" stroke-width="1"/>
        <text x="290" y="77" font-family="var(--font-mono)" font-size="9" fill="var(--color-key-text)">&lt;li&gt;item 1&lt;/li&gt;</text>
        <rect x="282" y="86" width="90" height="18" rx="3" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1.5"/>

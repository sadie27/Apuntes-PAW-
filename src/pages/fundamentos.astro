      <text x="50"  y="58" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-text)">Cliente</text>
      <rect x="260" y="35" width="80" height="36" rx="6" fill="var(--color-surface)" stroke="var(--color-border-strong)" stroke-width="1.5"/>
      <text x="300" y="58" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-text)">Servidor</text>
      <rect x="135" y="106" width="90" height="36" rx="6" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
      <text x="180" y="129" text-anchor="middle" font-family="var(--font-display)" font-size="11" fill="var(--color-text-2)">Leer fichero</text>
      <line x1="90" y1="53" x2="258" y2="53" stroke="var(--color-accent)" stroke-width="1.5"/>
      <polygon points="254,48 263,53 254,58" fill="var(--color-accent)"/>
      <text x="174" y="46" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-accent)">GET</text>
      <line x1="300" y1="71" x2="300" y2="104" stroke="var(--color-border-strong)" stroke-width="1.5"/>
      <line x1="300" y1="104" x2="225" y2="104" stroke="var(--color-border-strong)" stroke-width="1.5"/>
      <polygon points="229,99 220,104 229,109" fill="var(--color-border-strong)"/>
      <line x1="135" y1="124" x2="92" y2="124" stroke="var(--color-text-2)" stroke-width="1.5"/>
      <line x1="92" y1="124" x2="92" y2="70" stroke="var(--color-text-2)" stroke-width="1.5"/>
      <polygon points="87,74 96,70 87,66" fill="var(--color-text-2)"/>
      <text x="50" y="145" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-text-2)">HTML</text>

      <line x1="340" y1="10" x2="340" y2="190" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,4"/>

      <text x="510" y="22" text-anchor="middle" font-family="var(--font-display)" font-size="12"

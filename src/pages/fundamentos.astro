      <text x="30" y="45" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-2)">nombre="Ana"</text>
      <rect x="20" y="58" width="240" height="22" rx="4" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="1"/>
      <text x="30" y="73" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-2)">email="ana@mail.com"</text>
      <!-- botón enviar -->

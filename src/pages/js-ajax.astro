        <text x="405" y="207" font-family="var(--font-mono)" font-size="9" fill="var(--color-tip-text)" text-anchor="middle">Access-Control-Allow-Origin: http://dominioA.com</text>
        <!-- Paso 4: navegador da acceso -->
        <circle cx="22" cy="255" r="10" fill="var(--color-tip-text)"/>
        <text x="22" y="259" font-family="var(--font-display)" font-size="9" fill="var(--color-surface)" font-weight="700" text-anchor="middle">4</text>
        <rect x="40" y="240" width="320" height="28" rx="6" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1.5"/>

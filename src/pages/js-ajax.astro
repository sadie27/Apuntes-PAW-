        <text x="168" y="122" font-family="var(--font-mono)" font-size="10" fill="var(--color-key-text)" font-weight="600">JSON.stringify()</text>
        <text x="168" y="135" font-family="var(--font-body)" font-size="8" fill="var(--color-text-2)">objeto → texto</text>
        <!-- JSON.parse() -->
        <line x1="160" y1="154" x2="160" y2="188" stroke="var(--color-border-strong)" stroke-width="1.5" marker-end="url(#arr-json2)"/>
        <text x="168" y="170" font-family="var(--font-mono)" font-size="10" fill="var(--color-text-2)" font-weight="600">JSON.parse()</text>
        <text x="168" y="183" font-family="var(--font-body)" font-size="8" fill="var(--color-text-2)">texto → objeto</text>

        <!-- Servidor Java -->
        <rect x="450" y="20" width="300" height="200" rx="8" fill="var(--color-surface-2)" stroke="var(--color-border)" stroke-width="1.5"/>
        <text x="600" y="42" font-family="var(--font-display)" font-size="13" fill="var(--color-text)" font-weight="700" text-anchor="middle">Servidor (Java)</text>
        <rect x="466" y="52" width="268" height="50" rx="5" fill="var(--color-tip-bg)" stroke="var(--color-tip-border)" stroke-width="1"/>
        <text x="600" y="74" font-family="var(--font-mono)" font-size="11" fill="var(--color-tip-text)" text-anchor="middle" font-weight="600">Objetos Java</text>
        <text x="600" y="91" font-family="var(--font-body)" font-size="9" fill="var(--color-tip-text)" text-anchor="middle">new Cliente("C123", "Pepe")</text>
        <!-- Gson.toJson() -->
        <line x1="600" y1="102" x2="600" y2="136" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#arr-json1)"/>
        <text x="608" y="122" font-family="var(--font-mono)" font-size="10" fill="var(--color-tip-text)" font-weight="600">Gson.toJson()</text>
        <text x="608" y="135" font-family="var(--font-body)" font-size="8" fill="var(--color-text-2)">objeto → JSON</text>

        <text x="470" y="242" font-family="var(--font-body)" font-size="8" fill="var(--color-warning-text)" text-anchor="middle">cualquier error de red</text>
        <text x="470" y="255" font-family="var(--font-body)" font-size="8" fill="var(--color-warning-text)" text-anchor="middle">(captura desde cualquier paso)</text>

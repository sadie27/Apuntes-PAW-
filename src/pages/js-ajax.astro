        <text x="210" y="32" font-family="var(--font-display)" font-size="13" fill="var(--color-text)" font-weight="700" text-anchor="middle">Web Tradicional</text>
        <!-- Franja cliente -->
        <rect x="10" y="42" width="400" height="130" rx="0" fill="var(--color-surface-2)" stroke="none"/>
        <text x="22" y="60" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)" font-weight="600">CLIENTE</text>
        <!-- Bloques de actividad usuario -->
        <rect x="22" y="68" width="70" height="88" rx="4" fill="var(--color-accent-light)" stroke="var(--color-accent)" stroke-width="1.5"/>
        <text x="57" y="116" font-family="var(--font-body)" font-size="9" fill="var(--color-key-text)" text-anchor="middle">Actividad</text>
        <rect x="172" y="68" width="70" height="88" rx="4" fill="var(--color-accent-light)" stroke="var(--color-accent)" stroke-width="1.5"/>
        <text x="207" y="116" font-family="var(--font-body)" font-size="9" fill="var(--color-key-text)" text-anchor="middle">Actividad</text>
        <rect x="322" y="68" width="70" height="88" rx="4" fill="var(--color-accent-light)" stroke="var(--color-accent)" stroke-width="1.5"/>
        <text x="357" y="116" font-family="var(--font-body)" font-size="9" fill="var(--color-key-text)" text-anchor="middle">Actividad</text>
        <!-- Texto "bloqueado" -->
        <text x="135" y="105" font-family="var(--font-display)" font-size="9" fill="var(--color-warning-text)" text-anchor="middle" font-weight="600">bloqueado</text>
        <text x="285" y="105" font-family="var(--font-display)" font-size="9" fill="var(--color-warning-text)" text-anchor="middle" font-weight="600">bloqueado</text>
        <!-- Línea divisoria cliente/servidor -->
        <line x1="10" y1="172" x2="410" y2="172" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4,3"/>
        <!-- Franja servidor -->
        <text x="22" y="192" font-family="var(--font-display)" font-size="10" fill="var(--color-text-3)" font-weight="600">SERVIDOR</text>

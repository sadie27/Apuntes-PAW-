---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const links = [
  { href: base,                          label: 'Inicio' },
  { href: `${base}fundamentos`,          label: 'Fundamentos' },
  { href: `${base}jdbc`,                 label: 'JDBC' },
  { href: `${base}arquitectura`,         label: 'Arquitectura' },
  { href: `${base}servlets-jsp`,         label: 'Servlets/JSP' },
  { href: `${base}seguridad`,            label: 'Seguridad' },
  { href: `${base}javascript`,           label: 'JavaScript' },
  { href: `${base}js-ajax`,             label: 'JS + AJAX' },
];

function isActive(href: string): boolean {
  if (href === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(href);
}
---
<nav class="navbar" aria-label="Navegación principal">
  <div class="navbar-inner">
    <a href={base} class="navbar-brand">PAW</a>
    <ul class="navbar-links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['navbar-link', { 'navbar-link--active': isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: var(--z-navbar);
    height: var(--navbar-height);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--space-6);
  }

  .navbar-brand {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
  }

  .navbar-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-2);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: 4px;
    border-bottom: 2px solid transparent;
    transition: color 150ms ease;
    display: block;
  }

  .navbar-link--active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  @media (hover: hover) and (pointer: fine) {
    .navbar-link:not(.navbar-link--active):hover {
      color: var(--color-accent-hover);
    }
  }

  .navbar-link:active {
    transform: scale(0.97);
    transition: transform 80ms var(--ease-out);
  }
</style>

---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const links = [
  { href: base,                          label: 'Inicio' },
  { href: `${base}fundamentos`,          label: 'Fundamentos' },
  { href: `${base}jdbc`,                 label: 'JDBC' },
  { href: `${base}arquitectura`,         label: 'Arquitectura' },
  { href: `${base}servlets-jsp`,         label: 'Servlets/JSP' },
  { href: `${base}seguridad`,            label: 'Seguridad' },
  { href: `${base}javascript`,           label: 'JavaScript' },
  { href: `${base}js-ajax`,             label: 'JS + AJAX' },
  { href: `${base}practicas`,          label: 'Prácticas' },
  { href: `${base}examen`,             label: 'Examen' },
];

function isActive(href: string): boolean {
  if (href === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(href);
}
---
<header>
  <nav class="navbar" aria-label="Navegación principal">
    <div class="navbar-inner">
      <a href={base} class="navbar-brand">PAW</a>
      <button
        class="nav-hamburger"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="nav-mobile-menu-panel"
      >
        <span class="nav-hamburger-bar"></span>
        <span class="nav-hamburger-bar"></span>
        <span class="nav-hamburger-bar"></span>
      </button>
      <ul class="navbar-links" id="nav-mobile-menu" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['navbar-link', { 'navbar-link--active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <div class="nav-mobile-panel" id="nav-mobile-menu-panel" aria-hidden="true">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['nav-mobile-link', { 'active': isActive(link.href) }]}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<style>
  header {
    position: relative;
  }

  .navbar {
    position: sticky;
    top: 0;
    z-index: var(--z-navbar);
    height: var(--navbar-height);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--space-6);
  }

  .navbar-brand {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
  }

  .navbar-link {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-2);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: 4px;
    border-bottom: 2px solid transparent;
    transition: color 150ms ease;
    display: block;
  }

  .navbar-link--active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  @media (hover: hover) and (pointer: fine) {
    .navbar-link:not(.navbar-link--active):hover {
      color: var(--color-accent-hover);
    }
  }

  .navbar-link:active {
    transform: scale(0.97);
    transition: transform 80ms var(--ease-out);
  }

  /* ── Hamburguesa ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 6px;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 4px;
  }

  .nav-hamburger-bar {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
    transition: transform 180ms var(--ease-out), opacity 150ms ease;
  }

  .nav-hamburger[aria-expanded="true"] .nav-hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .nav-hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-hamburger[aria-expanded="true"] .nav-hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Panel mobile ── */
  .nav-mobile-panel {
    display: none;
    position: absolute;
    top: var(--navbar-height);
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-3) var(--space-5) var(--space-4);
    z-index: var(--z-navbar);
  }

  @keyframes panelEnter {
    from { transform: translateY(-8px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .nav-mobile-panel.is-open {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    animation: panelEnter 220ms var(--ease-out) forwards;
  }

  .nav-mobile-link {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: var(--space-3) var(--space-2);
    border-radius: 4px;
    transition: color 150ms ease, background 150ms ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .nav-mobile-link:hover {
      color: var(--color-accent);
      background: var(--color-accent-light);
    }
  }

  .nav-mobile-link.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* ── Breakpoint mobile ── */
  @media (max-width: 900px) {
    .nav-hamburger {
      display: flex;
    }

    #nav-mobile-menu {
      display: none;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('.nav-hamburger') as HTMLButtonElement | null;
  const panel = document.querySelector('.nav-mobile-panel') as HTMLElement | null;

  if (hamburger && panel) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.addEventListener('click', (e) => {
      if (!hamburger.contains(e.target as Node) && !panel.contains(e.target as Node)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });

    panel.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu());
    });

    function openMenu() {
      hamburger!.setAttribute('aria-expanded', 'true');
      panel!.setAttribute('aria-hidden', 'false');
      panel!.classList.add('is-open');
    }

    function closeMenu() {
      hamburger!.setAttribute('aria-expanded', 'false');
      panel!.setAttribute('aria-hidden', 'true');
      panel!.classList.remove('is-open');
    }
  }
</script>
